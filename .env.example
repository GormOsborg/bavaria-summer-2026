# Supabase project URL and anon key (used for public reads on the client + server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key, server-only. NEVER prefix with NEXT_PUBLIC.
# Used for inserts/deletes from server actions, bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared password the skipper gives friends in the group chat.
# Required to book or cancel a stay.
TRIP_PASSWORD=changeme
